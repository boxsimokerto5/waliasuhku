{
  "entities": {
    "User": {
      "title": "User",
      "description": "Profil pengguna pada aplikasi WaliAsuhku.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string",
          "description": "ID unik pengguna"
        },
        "username": {
          "type": "string",
          "description": "Username unik untuk login"
        },
        "name": {
          "type": "string",
          "description": "Nama lengkap pengguna"
        },
        "role": {
          "type": "string",
          "enum": ["super_admin", "wali_asuh", "anak_asuh"],
          "description": "Peran pengguna"
        },
        "password": {
          "type": "string",
          "description": "Password terenkripsi/tersimpan"
        },
        "waliAsuhId": {
          "type": "string",
          "description": "ID Wali Asuh (opsional, hanya untuk anak asuh)"
        },
        "createdAt": {
          "type": "string",
          "description": "Waktu pembuatan akun"
        },
        "savingsBalance": {
          "type": "integer",
          "description": "Saldo tabungan siswa (anak asuh)"
        },
        "fotoUrl": {
          "type": "string",
          "description": "URL Foto profil / foto anak asuh"
        },
        "alamat": {
          "type": "string",
          "description": "Alamat tempat tinggal asal"
        },
        "nik": {
          "type": "string",
          "description": "Nomor Induk Kependudukan (NIK)"
        },
        "kk": {
          "type": "string",
          "description": "Nomor Kartu Keluarga (KK)"
        },
        "parentPhone": {
          "type": "string",
          "description": "Nomor Handphone Orang Tua / Wali"
        },
        "email": {
          "type": "string",
          "description": "Alamat Email aktif"
        },
        "portfolio": {
          "type": "array",
          "description": "Daftar portofolio prestasi dan karya anak asuh"
        }
      },
      "required": ["id", "username", "name", "role", "createdAt"]
    },
    "Report": {
      "title": "Report",
      "description": "Laporan terenkripsi yang diajukan oleh anak asuh.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "senderId": {
          "type": "string"
        },
        "senderName": {
          "type": "string"
        },
        "receiverId": {
          "type": "string"
        },
        "receiverName": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "type": {
          "type": "string",
          "enum": ["pengaduan", "pelaporan", "curhatan"]
        },
        "status": {
          "type": "string",
          "enum": ["pending", "processed", "resolved"]
        },
        "attachmentUrl": {
          "type": "string"
        },
        "isEncrypted": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string"
        },
        "replies": {
          "type": "array"
        }
      },
      "required": ["id", "senderId", "senderName", "receiverId", "receiverName", "title", "content", "type", "status", "isEncrypted", "createdAt", "replies"]
    },
    "AppNotification": {
      "title": "AppNotification",
      "description": "Notifikasi dalam aplikasi untuk pengguna.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "userId": {
          "type": "string"
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        },
        "isRead": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["id", "userId", "title", "message", "isRead", "createdAt"]
    },
    "SavingsTransaction": {
      "title": "SavingsTransaction",
      "description": "Transaksi tabungan siswa (setor atau tarik) yang dikelola oleh Wali Asuh.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "studentId": {
          "type": "string"
        },
        "studentName": {
          "type": "string"
        },
        "waliAsuhId": {
          "type": "string"
        },
        "amount": {
          "type": "integer"
        },
        "type": {
          "type": "string",
          "enum": ["setor", "tarik"]
        },
        "description": {
          "type": "string"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["id", "studentId", "studentName", "waliAsuhId", "amount", "type", "description", "createdAt"]
    },
    "ChatMessage": {
      "title": "ChatMessage",
      "description": "Pesan chat real-time antara Wali Asuh dan Anak Asuh.",
      "type": "object",
      "properties": {
        "id": {
          "type": "string"
        },
        "senderId": {
          "type": "string"
        },
        "senderName": {
          "type": "string"
        },
        "senderRole": {
          "type": "string"
        },
        "receiverId": {
          "type": "string"
        },
        "receiverName": {
          "type": "string"
        },
        "content": {
          "type": "string"
        },
        "isEncrypted": {
          "type": "boolean"
        },
        "createdAt": {
          "type": "string"
        }
      },
      "required": ["id", "senderId", "senderName", "senderRole", "receiverId", "receiverName", "content", "isEncrypted", "createdAt"]
    }
  },
  "firestore": {
    "users/{userId}": {
      "schema": "User",
      "description": "Koleksi pengguna sistem"
    },
    "reports/{reportId}": {
      "schema": "Report",
      "description": "Koleksi laporan anak asuh"
    },
    "notifications/{notificationId}": {
      "schema": "AppNotification",
      "description": "Koleksi notifikasi real-time"
    },
    "savings_transactions/{transactionId}": {
      "schema": "SavingsTransaction",
      "description": "Koleksi transaksi tabungan siswa"
    },
    "chat_messages/{messageId}": {
      "schema": "ChatMessage",
      "description": "Koleksi pesan chat real-time"
    }
  }
}
